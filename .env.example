# ── Sports News Blog — environment template ──
# Copy to .env and fill in. NONE of these are needed for `npm run pipeline:dry-run`
# (the dry-run uses fixtures + mocks). They are required only for `pipeline:run` (live).

# Discovery
SERPER_API_KEY=
NEWSAPI_KEY=

# LLM — synthesis (KO write + EN translate) + fact-claim extraction.
# Routing: ANTHROPIC preferred; if absent, GEMINI_API_KEY drives synthesis too (full drop-in).
ANTHROPIC_API_KEY=
SYNTHESIS_MODEL=claude-sonnet-4-6
EXTRACTOR_MODEL=claude-sonnet-4-6

# LLM — advisory judges (tone/readability only; CANNOT block publication)
OPENAI_API_KEY=
# GEMINI_API_KEY: also powers the MANGA card art (gemini-2.5-flash-image) + scene/beats + (fallback) synthesis
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
JUDGE_CLAUDE_MODEL=claude-haiku-4-5
JUDGE_OPENAI_MODEL=gpt-4o-mini
JUDGE_GEMINI_MODEL=gemini-2.5-flash

# WordPress publish (SSH + wp-cli, Polylang KO/EN + Rank Math). Articles publish KO+EN;
# the Telegram card-news is KO-only (manga card doubles as the post featured image).
WP_SSH_HOST=
WP_SSH_USER=
WP_SSH_PORT=22
# Provide ONE of: a key file path, or an inline PEM (\n-escaped), or a password.
WP_SSH_KEY_PATH=
WP_SSH_KEY=
WP_SSH_PASSWORD=
WP_PATH=

# Telegram distribution (MVP channel) — KO manga card to the group
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=

# Behavior
SPORTS=football,baseball,basketball
MIN_SOURCES_PER_EVENT=2
PLAGIARISM_JACCARD_MAX=0.30
